// ==================== RESULT CARD ====================
interface ResultCardProps {
  result: Result;
  lang: Lang;
  txt: Translations;
  formatAnswer: (text: string) => string;
  copyToClipboard: (text: string) => void;
  delay: number;
}

function ResultCard({ result, lang, txt, formatAnswer, copyToClipboard, delay }: ResultCardProps) {
  const [copied, setCopied] = useState<boolean>(false);

  const handleCopy = (): void => {
    copyToClipboard(`${result.question}\n\n${result.answer}`);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const handleShare = async (): Promise<void> => {
    const text = `${result.question}\n\n${result.answer}\n\n— المسائل الشرعية الشيعية`;
    if (navigator.share) {
      await navigator.share({ title: "مسألة شرعية", text });
    } else {
      copyToClipboard(text);
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    }
  };

  return (
    <div
      className="result-card"
      style={{ marginBottom: "16px", padding: "20px", animationDelay: `${delay}s` }}
    >
      {/* Question */}
      <div
        style={{
          display: "flex", alignItems: "flex-start", gap: 10,
          marginBottom: "16px", paddingBottom: "14px",
          borderBottom: "1px solid rgba(201,168,76,0.1)",
        }}
      >
        <div style={{
          width: 28, height: 28, borderRadius: "50%",
          background: "rgba(201,168,76,0.15)", border: "1px solid rgba(201,168,76,0.3)",
          display: "flex", alignItems: "center", justifyContent: "center",
          fontSize: 14, flexShrink: 0,
        }}>❓</div>
        <p style={{ fontSize: "15px", color: "#e8d5a3", lineHeight: 1.7, fontWeight: 600 }}>
          {result.question}
        </p>
      </div>

      {/* Answer */}
      <div style={{ display: "flex", alignItems: "flex-start", gap: 10, marginBottom: "16px" }}>
        <div style={{
          width: 28, height: 28, borderRadius: "50%",
          background: "linear-gradient(135deg, rgba(201,168,76,0.3), rgba(201,168,76,0.1))",
          border: "1px solid rgba(201,168,76,0.4)",
          display: "flex", alignItems: "center", justifyContent: "center",
          fontSize: 14, flexShrink: 0,
        }}>📜</div>
        <div
          style={{ fontSize: "14px", color: "rgba(232,213,163,0.85)", lineHeight: 1.9 }}
          dangerouslySetInnerHTML={{ __html: `<p class="answer-para">${formatAnswer(result.answer)}</p>` }}
        />
      </div>

      {/* Footer */}
      <div style={{
        display: "flex", alignItems: "center", justifyContent: "space-between",
        paddingTop: "12px", borderTop: "1px solid rgba(201,168,76,0.08)",
      }}>
        <span style={{ fontSize: "11px", color: "rgba(232,213,163,0.3)" }}>
          🕐 {result.timestamp}
        </span>
        <div style={{ display: "flex", gap: 8 }}>
          <button className="icon-btn" onClick={handleCopy} style={{ fontFamily: "inherit", fontSize: 11 }}>
            {copied ? `✅ ${txt.copied}` : `📋 ${txt.copy}`}
          </button>
          <button className="icon-btn" onClick={handleShare} style={{ fontFamily: "inherit", fontSize: 11 }}>
            📤 {txt.share}
          </button>
        </div>
      </div>
    </div>
  );
}

