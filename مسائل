            width: 38, height: 38, borderRadius: "50%",
            background: "linear-gradient(135deg, #c9a84c, #7a5c1e)",
            display: "flex", alignItems: "center", justifyContent: "center",
            fontSize: "18px", boxShadow: "0 4px 15px rgba(201,168,76,0.3)",
          }}>☪</div>
          <div>
            <div style={{ fontSize: "15px", fontWeight: "700", color: "#c9a84c", lineHeight: 1.2 }}>
              {txt.title}
            </div>
            <div style={{ fontSize: "10px", color: "rgba(232,213,163,0.4)", lineHeight: 1 }}>
              {lang === "ar" ? "السيد علي السيستاني" : "Sayyid Al-Sistani"}
            </div>
          </div>
        </div>
        <button className="lang-toggle" onClick={() => setLang(lang === "ar" ? "en" : "ar")}>
          {lang === "ar" ? "EN" : "عربي"}
        </button>
      </header>

      {/* Hero */}
      <div style={{ textAlign: "center", padding: "32px 20px 24px", position: "relative" }}>
        <div style={{
          width: 100, height: 100, borderRadius: "50%",
          border: "2px solid rgba(201,168,76,0.3)",
          margin: "0 auto 16px", display: "flex", alignItems: "center", justifyContent: "center",
          position: "relative", animation: "pulse 3s infinite",
        }}>
          <div style={{
            width: 80, height: 80, borderRadius: "50%",
            border: "1px solid rgba(201,168,76,0.2)",
            display: "flex", alignItems: "center", justifyContent: "center",
          }}>
            <div style={{
              width: 60, height: 60, borderRadius: "50%",
              background: "radial-gradient(circle, rgba(201,168,76,0.15), transparent)",
              display: "flex", alignItems: "center", justifyContent: "center", fontSize: 28,
            }}>🕌</div>
          </div>
          {[0, 60, 120, 180, 240, 300].map((deg: number, i: number) => (
            <div key={i} style={{
              position: "absolute", width: 6, height: 6, borderRadius: "50%",
              background: "#c9a84c", opacity: 0.4 + i * 0.1,
              transform: `rotate(${deg}deg) translateX(50px)`,
            }} />
          ))}
        </div>
        <div style={{ color: "#c9a84c88", fontSize: 24, marginBottom: 8, letterSpacing: 8, animation: "shimmer 3s infinite" }}>
          ✦ ✦ ✦
        </div>
        <h1 style={{ fontSize: "22px", fontWeight: "700", color: "#c9a84c", marginBottom: "6px", textShadow: "0 0 30px rgba(201,168,76,0.3)" }}>
          {txt.title}
        </h1>
        <p style={{ fontSize: "13px", color: "rgba(232,213,163,0.5)", marginBottom: 4 }}>{txt.subtitle}</p>
        <p style={{ fontSize: "12px", color: "rgba(232,213,163,0.3)" }}>
          {lang === "ar" ? "بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ" : "In the name of Allah, the Most Gracious"}
        </p>
      </div>

      {/* Tabs */}
      <div style={{
        display: "flex", justifyContent: "center", gap: "4px",
        padding: "0 20px 16px", borderBottom: "1px solid rgba(201,168,76,0.1)",
      }}>
        {tabs.map((tab) => (
          <button
            key={tab.id}
            className={`tab-btn ${activeTab === tab.id ? "active" : ""}`}
            onClick={() => setActiveTab(tab.id)}
            style={{ padding: "10px 18px", fontSize: "13px", fontWeight: "600", fontFamily: "inherit" }}
          >
            {tab.icon} {tab.label}
            {tab.id === "history" && results.length > 0 && (
              <span style={{
                marginInlineStart: 6, background: "#c9a84c", color: "#0a0a12",
                borderRadius: "50%", width: 18, height: 18,
                display: "inline-flex", alignItems: "center", justifyContent: "center",
                fontSize: 10, fontWeight: 700,
              }}>{results.length}</span>
            )}
          </button>
        ))}
      </div>

      {/* Main */}
      <main style={{ padding: "20px", maxWidth: 680, margin: "0 auto", paddingBottom: 40 }}>

        {/* Search Tab */}
        {activeTab === "search" && (
          <div style={{ animation: "slideDown 0.3s ease" }}>
            <div className="glassmorphism" style={{ borderRadius: "20px", padding: "20px", marginBottom: "20px" }}>
              <textarea
                className="search-input"
                value={query}
                onChange={(e) => setQuery(e.target.value)}
                onKeyDown={(e) => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); handleSearch(); } }}
                placeholder={txt.placeholder}
                rows={3}
                style={{
                  width: "100%", borderRadius: "12px", padding: "14px 16px",
                  fontSize: "15px", fontFamily: "inherit", resize: "none",
                  lineHeight: 1.6, marginBottom: "12px", display: "block",
                }}
              />
              <button
                className="search-btn"
                onClick={() => handleSearch()}
                disabled={loading || !query.trim()}
                style={{
                  width: "100%", padding: "14px", borderRadius: "12px",
                  fontSize: "16px", fontFamily: "inherit",
                  display: "flex", alignItems: "center", justifyContent: "center", gap: "8px",
                  opacity: loading || !query.trim() ? 0.6 : 1,
                }}
              >
                {loading ? (
                  <>
                    <div style={{ display: "flex", gap: 4 }}>
                      {[0, 1, 2].map((i: number) => (
                        <div key={i} className="loading-dot" style={{ animationDelay: `${i * 0.2}s` }} />
                      ))}
                    </div>
                    {txt.searching}
                  </>
                ) : (<>🔍 {txt.search}</>)}
              </button>
            </div>

            {results.length === 0 && !loading && (
              <div style={{ marginBottom: "20px" }}>
                <p style={{ fontSize: "12px", color: "rgba(232,213,163,0.35)", marginBottom: "12px", textAlign: "center" }}>
                  {lang === "ar" ? "أمثلة على المسائل:" : "Example questions:"}
                </p>
                <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                  {[txt.example1, txt.example2, txt.example3].map((ex: string, i: number) => (
                    <button
                      key={i} className="example-chip"
                      onClick={() => { setQuery(ex); handleSearch(ex); }}
                      style={{ textAlign: lang === "ar" ? "right" : "left", fontFamily: "inherit" }}
                    >
                      ◆ {ex}
                    </button>
                  ))}
                </div>
              </div>
            )}

            <div ref={resultsRef}>
              {results.map((result: Result, idx: number) => (
                <ResultCard key={result.id} result={result} lang={lang} txt={txt}
                  formatAnswer={formatAnswer} copyToClipboard={copyToClipboard} delay={idx * 0.1} />
              ))}
            </div>
          </div>
        )}

        {/* History Tab */}
        {activeTab === "history" && (
          <div style={{ animation: "slideDown 0.3s ease" }}>
            {results.length > 0 ? (
              <>
                <div style={{ display: "flex", justifyContent: "flex-end", marginBottom: 16 }}>
                  <button className="icon-btn" onClick={() => { setResults([]); setHistory([]); }} style={{ fontFamily: "inherit" }}>
                    🗑 {txt.clearHistory}
                  </button>
                </div>
                {results.map((result: Result, idx: number) => (
                  <ResultCard key={result.id} result={result} lang={lang} txt={txt}
                    formatAnswer={formatAnswer} copyToClipboard={copyToClipboard} delay={idx * 0.05} />
                ))}
              </>
            ) : (
              <EmptyState lang={lang} />
            )}
          </div>
        )}

        {/* About Tab */}
        {activeTab === "about" && (
          <div style={{ animation: "slideDown 0.3s ease" }}>
            <AboutSection lang={lang} txt={txt} books={BOOKS} />
          </div>
        )}
      </main>

      {/* Footer */}
      <div style={{
        textAlign: "center", padding: "16px",
        borderTop: "1px solid rgba(201,168,76,0.1)",
        color: "rgba(232,213,163,0.25)", fontSize: "11px",
      }}>
        {lang === "ar"
          ? "جميع الأحكام مستندة إلى مراجع السيد علي السيستاني المعتمدة"
          : "All rulings are based on Sayyid Al-Sistani's official references"}
      </div>
    </div>
  );
}
