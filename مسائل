        .search-btn:active { transform: scale(0.98); }
        .search-input { background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.25); color: #e8d5a3; outline: none; transition: all 0.3s; backdrop-filter: blur(10px); }
