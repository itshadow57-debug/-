// ==================== MAIN APP ====================
export default function App() {
  const [lang, setLang] = useState<Lang>("ar");
  const [query, setQuery] = useState<string>("");
  const [results, setResults] = useState<Result[]>([]);
  const [loading, setLoading] = useState<boolean>(false);
  const [history, setHistory] = useState<Message[]>([]);
  const [activeTab, setActiveTab] = useState<TabId>("search");
  const [particles, setParticles] = useState<Particle[]>([]);
  const resultsRef = useRef<HTMLDivElement>(null);

  const txt: Translations = TRANSLATIONS[lang];

  useEffect(() => {
    const pts: Particle[] = Array.from({ length: 20 }, (_, i) => ({
      id: i,
      x: Math.random() * 100,
      y: Math.random() * 100,
      size: Math.random() * 3 + 1,
      speed: Math.random() * 20 + 10,
      delay: Math.random() * 5,
    }));
    setParticles(pts);
  }, []);

  const formatAnswer = (text: string): string => {
    return text
      .replace(/\*\*(.*?)\*\*/g, '<strong class="highlight-text">$1</strong>')
      .replace(/\n\n/g, '</p><p class="answer-para">')
      .replace(/\n/g, "<br/>");
  };

  const copyToClipboard = (text: string): void => {
    navigator.clipboard.writeText(text);
  };

  const handleSearch = async (searchQuery?: string): Promise<void> => {
    const q = searchQuery || query;
    if (!q.trim()) return;
    setLoading(true);
    setActiveTab("search");

    const userMsg: Message = { role: "user", content: q };
    const newHistory: Message[] = [...history, userMsg];

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: SYSTEM_PROMPT,
          messages: newHistory,
        }),
      });

      const data = await response.json();
      const answer: string = data.content?.[0]?.text || "لم يتم الحصول على إجابة";
      const assistantMsg: Message = { role: "assistant", content: answer };
      setHistory([...newHistory, assistantMsg]);

      setResults((prev) => [{
        id: Date.now(),
        question: q,
        answer,
        timestamp: new Date().toLocaleString(lang === "ar" ? "ar-IQ" : "en-US"),
      }, ...prev]);
    } catch (err) {
      setResults((prev) => [{
        id: Date.now(),
        question: q,
        answer: "حدث خطأ في الاتصال. يرجى المحاولة مرة أخرى.",
        timestamp: new Date().toLocaleString(),
        error: true,
      }, ...prev]);
    }

    setLoading(false);
    setQuery("");
    setTimeout(() => resultsRef.current?.scrollIntoView({ behavior: "smooth" }), 100);
  };

  const tabs: { id: TabId; label: string; icon: string }[] = [
    { id: "search", label: txt.searchTab, icon: "🔍" },
    { id: "history", label: txt.history, icon: "📖" },
    { id: "about", label: txt.about, icon: "ℹ️" },
  ];

  return (
    <div
      dir={lang === "ar" ? "rtl" : "ltr"}
      style={{
        minHeight: "100vh",
        background: "linear-gradient(135deg, #0a0a12 0%, #0d1117 40%, #0a1220 70%, #06080f 100%)",
        fontFamily: lang === "ar" ? "'Amiri', 'Scheherazade New', serif" : "'Cormorant Garamond', serif",
        color: "#e8d5a3",
        overflowX: "hidden",
        position: "relative",
      }}
    >
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Scheherazade+New:wght@400;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0a0a12; }
        ::-webkit-scrollbar-thumb { background: #c9a84c; border-radius: 3px; }
        .particle { position: fixed; border-radius: 50%; background: radial-gradient(circle, #c9a84c88, transparent); pointer-events: none; animation: floatUp linear infinite; }
        @keyframes floatUp { 0% { transform: translateY(100vh) scale(0); opacity: 0; } 10% { opacity: 0.6; } 90% { opacity: 0.2; } 100% { transform: translateY(-20vh) scale(1.5); opacity: 0; } }
        @keyframes shimmer { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse { 0%, 100% { box-shadow: 0 0 20px #c9a84c44; } 50% { box-shadow: 0 0 40px #c9a84caa, 0 0 80px #c9a84c44; } }
        @keyframes loadingDot { 0%, 80%, 100% { transform: scale(0.8); opacity: 0.4; } 40% { transform: scale(1.2); opacity: 1; } }
        .search-btn { background: linear-gradient(135deg, #c9a84c, #a07830, #c9a84c); background-size: 200% 200%; border: none; color: #0a0a12; font-weight: 700; cursor: pointer; transition: all 0.3s; animation: pulse 3s infinite; }
